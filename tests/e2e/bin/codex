#!/usr/bin/env python3

import json
import os
import sys
import time
from pathlib import Path


def main() -> int:
    args = sys.argv[1:]
    prompt = args[-1] if args else ""
    workdir = Path.cwd()

    if "[slow]" in prompt:
        time.sleep(float(os.getenv("AGENTFLOW_MOCK_SLOW_SECONDS", "5")))

    if "[flaky]" in prompt:
        marker = workdir / ".e2e-flaky"
        if not marker.exists():
            marker.write_text("first failure", encoding="utf-8")
            print("first flaky failure", file=sys.stderr, flush=True)
            return 7

    payload = {
        "type": "response.output_item.done",
        "item": {
            "type": "message",
            "role": "assistant",
            "content": [{"type": "output_text", "text": prompt}],
        },
    }
    print(json.dumps(payload), flush=True)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
