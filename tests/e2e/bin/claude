#!/usr/bin/env python3

import json
import os
import sys
import time


def _prompt(args: list[str]) -> str:
    if "-p" in args:
        index = args.index("-p")
        if index + 1 < len(args):
            return args[index + 1]
    return args[-1] if args else ""


def main() -> int:
    args = sys.argv[1:]
    prompt = _prompt(args)

    if "[slow]" in prompt:
        time.sleep(float(os.getenv("AGENTFLOW_MOCK_SLOW_SECONDS", "5")))

    print(json.dumps({"type": "assistant", "message": {"content": [{"type": "text", "text": prompt}]}}), flush=True)
    print(json.dumps({"type": "result", "result": prompt}), flush=True)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
